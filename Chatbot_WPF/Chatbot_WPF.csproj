  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Windows.Extensions" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Blue.drawio.png" />
    <Resource Include="Pink.drawio.png" />
    <Resource Include="PROGTITLE_IMAGE.jpg" />
  </ItemGroup>

</Project>
