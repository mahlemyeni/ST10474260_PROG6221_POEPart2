<Window x:Class="Chatbot_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:Chatbot_WPF"
        mc:Ignorable="d"
        Title="Cybersecurity Chatbot" Height="700" Width="1000"
        Background="#F5F5F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Left Column: Chat Interface -->
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text=" Cybersecurity Chat Assistant" 
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1F4788"/>

            <!-- Chat Display -->
            <ScrollViewer x:Name="ChatScrollViewer" Height="500" 
                         Background="White" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,10">
                <ListBox x:Name="ChatListBox" Background="White" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Sender}" FontWeight="Bold" 
                                              Foreground="{Binding IsUser, Converter={StaticResource SenderColorConverter}}"/>
                                    <TextBlock Text="{Binding Timestamp}" Margin="10,0,0,0" 
                                              Foreground="#999" FontSize="11"/>
                                </StackPanel>
                                <Border Background="{Binding IsUser, Converter={StaticResource UserToColorConverter}}"
                                        CornerRadius="5" Padding="10" Margin="0,5,0,5">
                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <!-- Input Area -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageTextBox" Grid.Column="0" Padding="10" Height="40"
                        KeyDown="MessageTextBox_KeyDown" VerticalContentAlignment="Center"
                        Foreground="#333" Background="White" BorderBrush="#DDD" BorderThickness="1"/>

                <Button x:Name="SendMessageButton" Grid.Column="1" Content="Send" Margin="5,0,0,0"
                       Click="SendMessageButton_Click" Background="#007ACC" Foreground="White"
                       FontWeight="Bold" Cursor="Hand"/>

                <Button x:Name="VoiceButton" Grid.Column="2" Content=" Voice" Margin="5,0,0,0"
                       Click="VoiceButton_Click" Background="#666" Foreground="White"
                       FontWeight="Bold" Cursor="Hand"/>
            </Grid>

            <Button x:Name="ClearButton" Content="Clear Chat" Margin="0,10,0,0"
                   Click="ClearButton_Click" Background="#CC5555" Foreground="White" Padding="10"/>
        </StackPanel>

        <!-- Right Column: Task Assistant, Quiz, and Log -->
        <TabControl Grid.Column="1" Margin="10">

            <!-- Tab 1: Task Assistant -->
            <TabItem Header=" Tasks" Background="White">
                <StackPanel Margin="10" Background="White">
                    <!-- Add Task Section -->
                    <TextBlock Text="Add New Task" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1F4788"/>

                    <TextBlock Text="Title:" FontSize="11" Foreground="#666" Margin="0,5,0,2"/>
                    <TextBox x:Name="TaskTitleTextBox" Padding="8" Height="30" Margin="0,0,0,8"
                            Background="White" BorderBrush="#DDD" BorderThickness="1"/>

                    <TextBlock Text="Description:" FontSize="11" Foreground="#666" Margin="0,5,0,2"/>
                    <TextBox x:Name="TaskDescriptionTextBox" Padding="8" Height="50" Margin="0,0,0,8"
                            Background="White" BorderBrush="#DDD" BorderThickness="1" TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Reminder:" FontSize="11" Foreground="#666" Margin="0,5,0,2"/>
                    <TextBox x:Name="TaskReminderTextBox" Padding="8" Height="30" Margin="0,0,0,8"
                            Background="White" BorderBrush="#DDD" BorderThickness="1"
                            Foreground="#999" Text="e.g., 3 days, tomorrow"/>

                    <Button x:Name="AddTaskButton" Content=" Add Task" Click="AddTaskButton_Click"
                           Background="#28A745" Foreground="White" Padding="8" Margin="0,0,0,15"
                           FontWeight="Bold" Cursor="Hand"/>

                    <!-- Tasks List -->
                    <TextBlock Text="Your Tasks" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1F4788"/>

                    <ScrollViewer Height="200" Background="White" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,10">
                        <ListBox x:Name="TaskListBox" Background="White" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8" Background="{Binding IsComplete, Converter={StaticResource UserToColorConverter}}">
                                        
                                        <TextBlock Text="{Binding Description}" Foreground="#666" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding Reminder}" Foreground="#999" FontSize="10" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding CreatedAt}" Foreground="#999" FontSize="9" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="CompleteTaskButton" Content="✓ Complete" Grid.Column="0" Margin="0,0,5,0"
                               Click="CompleteTaskButton_Click" Background="#17A2B8" Foreground="White"
                               Padding="8" FontWeight="Bold" Cursor="Hand"/>

                        <Button x:Name="DeleteTaskButton" Content="✕ Delete" Grid.Column="1" Margin="5,0,0,0"
                               Click="DeleteTaskButton_Click" Background="#DC3545" Foreground="White"
                               Padding="8" FontWeight="Bold" Cursor="Hand"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- Tab 2: Quiz -->
            <TabItem Header=" Quiz" Background="White">
                <StackPanel Margin="10" Background="White" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Cybersecurity Quiz" FontWeight="Bold" FontSize="14" 
                              Margin="0,0,0,15" Foreground="#1F4788" TextAlignment="Center"/>

                    <TextBlock Text="Test your cybersecurity knowledge!" Foreground="#666" 
                              Margin="0,0,0,20" TextAlignment="Center" TextWrapping="Wrap"/>


                    <Button Padding="15,10" FontSize="14" FontWeight="Bold"
    Background="#007ACC" Foreground="White" Cursor="Hand"
    Click="SendMessageButton_Click">
    <Button.Content>
        <TextBlock Text=" Start Quiz&#x0a;(Type 'start quiz' in chat)" TextAlignment="Center"/>
    </Button.Content>
</Button>

                    <TextBlock Text="• 13+ questions" Margin="0,20,0,3" Foreground="#666"/>
                    <TextBlock Text="• Multiple choice and True/False" Margin="0,3,0,3" Foreground="#666"/>
                    <TextBlock Text="• Instant feedback" Margin="0,3,0,3" Foreground="#666"/>
                    <TextBlock Text="• Final score with message" Margin="0,3,0,20" Foreground="#666"/>

                    <TextBlock Text="Topics:" Margin="0,0,0,5" FontWeight="Bold" Foreground="#1F4788"/>
                    <TextBlock Text="✓ Phishing Detection" Margin="5,3,0,3" Foreground="#666"/>
                    <TextBlock Text="✓ Password Security" Margin="5,3,0,3" Foreground="#666"/>
                    <TextBlock Text="✓ Safe Browsing" Margin="5,3,0,3" Foreground="#666"/>
                    <TextBlock Text="✓ Social Engineering" Margin="5,3,0,3" Foreground="#666"/>
                    <TextBlock Text="✓ 2FA &amp; Malware" Margin="5,3,0,20" Foreground="#666"/>
                </StackPanel>
            </TabItem>

            <!-- Tab 3: Activity Log -->
            <TabItem Header=" Log" Background="White">
                <StackPanel Margin="10" Background="White">
                    <TextBlock Text="Activity Log" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1F4788"/>

                    <TextBlock Text="View recent chatbot actions" Foreground="#666" Margin="0,0,0,10" FontSize="11"/>

                    <ScrollViewer Height="550" Background="White" BorderBrush="#DDD" BorderThickness="1">
                        <TextBlock x:Name="ActivityLogTextBlock" Padding="10" Foreground="#333"
                                  TextWrapping="Wrap" Text="Type 'show activity log' in the chat to view recent actions."/>
                    </ScrollViewer>

                    <Button Content=" Show Full Log" Padding="10" Margin="0,10,0,0"
                           Background="#666" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>

    <!-- Value Converters -->
    <Window.Resources>
        <local:UserToColorConverter x:Key="UserToColorConverter"/>
        <local:UserToAlignmentConverter x:Key="UserToAlignmentConverter"/>
        <local:SenderColorConverter x:Key="SenderColorConverter"/>
        
    </Window.Resources>
</Window>
