<Window x:Class="Chatbot_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chatbot_WPF"
        mc:Ignorable="d"
        Title="Cybersecurity Chatbot" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#f4f6f8">

    <Window.Resources>
        <local:UserToColorConverter x:Key="UserToColorConverter" />
        <local:UserToAlignmentConverter x:Key="UserToAlignmentConverter" />
        <local:SenderColorConverter x:Key="SenderColorConverter" />
    </Window.Resources>

   

    <Grid Margin="20,0,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Art -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ASCII Art as TextBlock -->
                <TextBlock x:Name="AsciiArt" Grid.Column="0" 
                           FontFamily="Consolas" FontSize="10" 
                           Foreground="#3498DB" TextWrapping="Wrap"
                           Text="╔════════════════════════════════════════╗&#x0A;║            CYBERSECURITY BOT           ║&#x0A;║            Stay Safe Online!           ║&#x0A;╚════════════════════════════════════════╝"
                           Margin="5"/> 

                <!-- Title -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                    
                    <TextBlock Text="CYBERSECURITY BOT" 
                               FontSize="22" FontWeight="Bold" 
                               Foreground="White" FontFamily="Segoe UI"/>
                    <TextBlock Text="Your Online Safety Companion" 
                               FontSize="12" Foreground="#BDC3C7"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Chat Display Area -->
        <Border Grid.Row="1" Background="White" Margin="10" CornerRadius="8" BorderBrush="#BDC3C7" BorderThickness="1">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="ChatListBox" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Margin="5"
                                    Background="{Binding IsUser, Converter={StaticResource UserToColorConverter}}"
                                    HorizontalAlignment="{Binding IsUser, Converter={StaticResource UserToAlignmentConverter}}"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Sender}" FontWeight="Bold"
                                               Foreground="{Binding IsUser, Converter={StaticResource SenderColorConverter}}"
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                               Foreground="Black" FontSize="14" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding Timestamp}" FontSize="10"
                                               Foreground="Gray" Margin="0,5,0,0"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>
        
        
        <!-- Input Area -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="10" CornerRadius="8" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="MessageTextBox" Grid.Column="0" 
                         Height="60" TextWrapping="Wrap" 
                         FontSize="14" VerticalContentAlignment="Center"
                         BorderBrush="#BDC3C7" BorderThickness="1" 
                         KeyDown="MessageTextBox_KeyDown"
                         ToolTip="Type your message here..."/>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Button x:Name="SendMessageButton" Content=" Send" 
                            Width="100" Height="35" Margin="0,0,0,5"
                            Foreground="White" Background="#3498DB" 
                            BorderBrush="#2980B9" BorderThickness="1"
                            Click="SendMessageButton_Click"
                            FontWeight="Bold"
                            Cursor="Hand"/>
                    <Button x:Name="VoiceButton" Content="Speak" 
                            Width="100" Height="35"
                            Foreground="White" Background="#E74C3C" 
                            BorderBrush="#C0392B" BorderThickness="1"
                            Click="VoiceButton_Click"
                            FontWeight="Bold"
                            Cursor="Hand"/>
                    <Button x:Name="ClearButton" Content="Clear" 
                            Width="100" Height="35" Margin="0,5,0,0"
                            Foreground="White" Background="#95A5A6" 
                            BorderBrush="#7F8C8D" BorderThickness="1"
                            Click="ClearButton_Click"
                            FontWeight="Bold"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window> 